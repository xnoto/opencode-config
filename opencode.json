    "argocd-prod-eks_get_resource_actions": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "webfetch": "allow",
    "websearch": "allow"
  },
  "agent": {
    "plan": {
      "disable": true
    },
    "build": {
      "disable": true
    }
  },
  "mcp": {
    "context-mode": {
      "type": "local",
      "command": [
        "context-mode"
      ],
      "enabled": true
    },
    "linear": {
      "type": "local",
      "command": [
        "bunx",
        "mcp-remote",
        "https://mcp.linear.app/sse"
      ],
      "enabled": true
    },
    "notion": {
      "type": "local",
      "command": [
        "bunx",
        "mcp-remote",
        "https://mcp.notion.com/sse"
      ],
      "enabled": true
    },
    "aws-api-staging": {
      "type": "local",
      "command": [
        "uvx",
        "awslabs.aws-api-mcp-server@latest"
      ],
      "enabled": true,
      "environment": {
        "READ_OPERATIONS_ONLY": "true",
        "AWS_REGION": "us-east-2",
        "AWS_API_MCP_PROFILE_NAME": "staging"
      }
    },
    "aws-api-prod": {
      "type": "local",
      "command": [
        "uvx",
        "awslabs.aws-api-mcp-server@latest"
      ],
      "enabled": true,
      "environment": {
        "READ_OPERATIONS_ONLY": "true",
        "AWS_REGION": "us-east-2",
        "AWS_API_MCP_PROFILE_NAME": "prod"
      }
    },
    "aws-docs": {
      "type": "local",
      "command": [
        "uvx",
        "awslabs.aws-documentation-mcp-server@latest"
      ],
      "enabled": true,
      "environment": {
        "FASTMCP_LOG_LEVEL": "ERROR",
        "AWS_DOCUMENTATION_PARTITION": "aws"
      }
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {env:GITHUB_TOKEN}"
      }
    },
    "grafana": {
      "type": "local",
      "command": [
        "podman",
        "run",
        "--rm",
        "-i",
        "-e",
        "GRAFANA_URL=https://hatchengineering.grafana.net",
        "-e",
        "GRAFANA_SERVICE_ACCOUNT_TOKEN",
        "docker.io/mcp/grafana:latest",
        "-t",
        "stdio"
      ],
      "enabled": true,
      "environment": {
        "GRAFANA_SERVICE_ACCOUNT_TOKEN": "{env:GRAFANA_TOKEN}"
      }
    },
    "agent-hub": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "agent-hub-mcp@latest"
      ],
      "enabled": true
    },
    "tmux": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "tmux-mcp"
      ],
      "enabled": true
    },
    "terraform-docs": {
      "type": "local",
      "command": [
        "podman",
        "run",
        "--rm",
        "-i",
        "docker.io/hashicorp/terraform-mcp-server:latest"
      ],
      "enabled": true
    },
    "opentofu-docs": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@opentofu/opentofu-mcp-server"
      ],
      "enabled": true
    },
    "kubernetes": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-server-kubernetes"
      ],
      "enabled": true,
      "environment": {
        "K8S_CONTEXT": "staging-eks.angler-elver.ts.net"
      }
    },
    "opencode-docs": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "opencode-docs-mcp@latest"
      ],
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "argocd-staging-eks": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "argocd-mcp@latest",
        "stdio"
      ],
      "enabled": true,
      "environment": {
        "ARGOCD_BASE_URL": "https://argocd-staging.angler-elver.ts.net",
        "ARGOCD_API_TOKEN": "{env:ARGOCD_STAGING_TOKEN}"
      }
    },
    "argocd-prod-eks": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "argocd-mcp@latest",
        "stdio"
      ],
      "enabled": true,
      "environment": {
        "ARGOCD_BASE_URL": "https://argocd-prod.angler-elver.ts.net",
        "ARGOCD_API_TOKEN": "{env:ARGOCD_PROD_TOKEN}"
      }
    }
  },
  "provider": {
    "llama.cpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama-server (hero)",
      "options": {
        "baseURL": "http://hero.makeitwork.cloud:8080/v1"
      },
      "models": {
        "qwen2.5-coder-32b-instruct-q4_k_m.gguf": {
          "name": "Qwen2.5-Coder-32B Q4_K_M (hero)",
          "limit": {
            "context": 8192,
            "output": 4096
          }
        }
      }
    }
  }
}
