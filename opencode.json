{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "plugin": ["opencode-mem", "context-mode"],
  "permission": {
    "*": "ask",
    "agent-hub_*": "allow",
    "bash": {
      "*": "ask",
      "gh pr list *": "allow",
      "gh pr view *": "allow",
      "gh run list *": "allow",
      "gh run view *": "allow",
      "gh run watch *": "allow",
      "git *": "allow",
      "git commit *": "ask",
      "git push *": "ask",
      "grep *": "allow",
      "ls *": "allow",
      "echo *": "allow",
      "pwd *": "allow",
      "pre-commit *": "allow"
    },
    "context-mode_ctx_batch_execute": "allow",
    "context-mode_ctx_doctor": "allow",
    "context-mode_ctx_execute": "allow",
    "context-mode_ctx_execute_file": "allow",
    "codesearch": "allow",
    "context-mode_ctx_fetch_and_index": "allow",
    "context-mode_ctx_index": "allow",
    "context-mode_ctx_search": "allow",
    "context-mode_ctx_stats": "allow",
    "context-mode_ctx_upgrade": "allow",
    "grep": "allow",
    "github_get_file_contents": "allow",
    "github_get_team_members": "allow",
    "github_search_code": "allow",
    "github_search_repositories": "allow",
    "grafana_get_dashboard_panel_queries": "allow",
    "grafana_get_dashboard_property": "allow",
    "grafana_get_dashboard_summary": "allow",
    "grafana_get_datasource_by_uid": "allow",
    "grafana_list_datasources": "allow",
    "grafana_list_loki_label_values": "allow",
    "grafana_list_prometheus_metric_names": "allow",
    "grafana_search_dashboards": "allow",
    "kubernetes_kubectl_describe": "allow",
    "kubernetes_kubectl_get": "allow",
    "kubernetes_kubectl_logs": "allow",
    "linear_get_issue": "allow",
    "linear_list_comments": "allow",
    "linear_list_issue_statuses": "allow",
    "linear_list_issues": "allow",
    "linear_list_teams": "allow",
    "list": "allow",
    "notion_notion-fetch": "allow",
    "notion_notion-search": "allow",
    "read": "allow",
    "skill": "allow",
    "tmux_list-panes": "allow",
    "tmux_capture-pane": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "webfetch": "allow",
    "websearch": "allow"
  },
  "agent": {
    "plan": {
      "disable": true
    },
    "build": {
      "disable": true
    }
  },
  "mcp": {
    "context-mode": {
      "type": "local",
      "command": ["context-mode"],
      "enabled": true
    },
    "linear": {
      "type": "local",
      "command": [
        "bunx",
        "mcp-remote",
        "https://mcp.linear.app/sse"
      ],
      "enabled": false
    },
    "notion": {
      "type": "local",
      "command": [
        "bunx",
        "mcp-remote",
        "https://mcp.notion.com/sse"
      ],
      "enabled": false
    },
    "aws-api-staging": {
      "type": "local",
      "command": [
        "uvx",
        "awslabs.aws-api-mcp-server@latest"
      ],
      "enabled": false,
      "environment": {
        "READ_OPERATIONS_ONLY": "true",
        "AWS_REGION": "us-east-2",
        "AWS_API_MCP_PROFILE_NAME": "staging"
      }
    },
    "aws-api-prod": {
      "type": "local",
      "command": [
        "uvx",
        "awslabs.aws-api-mcp-server@latest"
      ],
      "enabled": false,
      "environment": {
        "READ_OPERATIONS_ONLY": "true",
        "AWS_REGION": "us-east-2",
        "AWS_API_MCP_PROFILE_NAME": "prod"
      }
    },
    "aws-doc": {
      "type": "local",
      "command": [
        "uvx",
        "awslabs.aws-documentation-mcp-server@latest"
      ],
      "enabled": false,
      "environment": {
        "FASTMCP_LOG_LEVEL": "ERROR",
        "AWS_DOCUMENTATION_PARTITION": "aws"
      }
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {env:GITHUB_TOKEN}"
      }
    },
    "grafana": {
      "type": "local",
      "command": [
        "podman",
        "run",
        "--rm",
        "-i",
        "-e",
        "GRAFANA_URL=https://hatchengineering.grafana.net",
        "-e",
        "GRAFANA_SERVICE_ACCOUNT_TOKEN",
        "docker.io/mcp/grafana:latest",
        "-t",
        "stdio"
      ],
      "enabled": false,
      "environment": {
        "GRAFANA_SERVICE_ACCOUNT_TOKEN": "{env:GRAFANA_TOKEN}"
      }
    },
    "agent-hub": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "agent-hub-mcp@latest"
      ],
      "enabled": true
    },
    "tmux": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "tmux-mcp"
      ],
      "enabled": true
    },
    "terraform": {
      "type": "local",
      "command": [
        "podman",
        "run",
        "--rm",
        "-i",
        "docker.io/hashicorp/terraform-mcp-server:latest"
      ],
      "enabled": false
    },
    "opentofu": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@opentofu/opentofu-mcp-server"
      ],
      "enabled": false
    },
    "kubernetes": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-server-kubernetes"
      ],
      "enabled": false
    }
  }
}
